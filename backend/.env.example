# Backend Environment Variables
# Copy this file to .env and fill in real values.

# MongoDB Connection URI
# Atlas example:
# mongodb+srv://<db_username>:<db_password>@<cluster-url>/<db_name>?retryWrites=true&w=majority
MONGO_URI=

# JWT secrets
# Use long random strings in real deployments.
USER_JWT_SECRET=replace_with_a_strong_user_jwt_secret
MESS_JWT_SECRET=replace_with_a_strong_mess_jwt_secret

# Internal API key used by protected attendance/job endpoints
API_KEY_UPDATE_ATTENDANCE=replace_with_a_long_random_api_key

# Server settings
PORT=3000
NODE_ENV=development
